# Docker Container Overrides
# Copy this file to .env.docker - contains ONLY container-specific settings
# All other configuration comes from .env (baseline)

# 🏷️ Tags: (Infrastructure) = Docker / Makefile
# 🏷️ Tags: (App) = Python application runtime

# =============================================================================
# CONTAINER RUNTIME OVERRIDES
# =============================================================================

# API Configuration (Infrastructure)
API_HOST=0.0.0.0
API_RELOAD=false

# Redis Configuration (App + Infrastructure)
REDIS_HOST=redis

# Worker Configuration (App)
CELERY_CONCURRENCY=2

# Logging Configuration (App)
LOG_LEVEL=INFO
CELERY_LOG_LEVEL=INFO


# =============================================================================
# 📝 MINIMAL OVERRIDE APPROACH
# =============================================================================
# 🐳 LAYERED LOADING:
#    1. .env provides baseline configuration (dev-friendly defaults)  
#    2. .env.docker overrides only container-specific values
#    3. No duplication - ports, project names, API keys stay in .env 
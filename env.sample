# LLM Calendar Assistant - Complete Configuration Template
# Copy this file to .env and configure the required values
#
# 🏷️ Tags: (Infrastructure) = Docker / Makefile
# 🏷️ Tags: (App) = Python application runtime

# QUICK START (Set these required values)
#   DATABASE_HOST, DATABASE_PASSWORD, DATABASE_USER
#   OPENAI_API_KEY, ANTHROPIC_API_KEY

# =============================================================================
# PROJECT CONFIGURATION
# =============================================================================
# 📌 Must Exist
PROJECT_NAME=llm-calendar-assistant

# =============================================================================
# API CONFIGURATION (Infrastructure)
# =============================================================================
# 💡 Optional
API_HOST=localhost
API_PORT=8080
API_RELOAD=true

# =============================================================================
# WORKER CONFIGURATION (App)
# =============================================================================
# 📌 Must Exist
FLOWER_PORT=5555

# 💡 Optional
CELERY_CONCURRENCY=4
CELERY_LOG_LEVEL=DEBUG

# =============================================================================
# REDIS CONFIGURATION (App + Infrastructure)
# =============================================================================
# 📌 Must Exist
REDIS_HOST=localhost

# 💡 Optional
REDIS_PORT=6379
REDIS_DB=0

# =============================================================================
# DATABASE CONFIGURATION (App)
# =============================================================================
# 🔧 Must Set
DATABASE_HOST=your_supabase_host.supabase.com
DATABASE_PASSWORD=your_supabase_password
DATABASE_USER=postgres.your_project_id

# 💡 Optional
DATABASE_NAME=postgres
DATABASE_PORT=6543

# =============================================================================
# LLM PROVIDERS (App)
# =============================================================================
# 🔧 Must Set
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# 💡 Optional - OpenAI Settings
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.0
OPENAI_MAX_TOKENS=2048
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT=30

# 💡 Optional - Anthropic Settings
ANTHROPIC_MODEL=claude-3-sonnet-20240229
ANTHROPIC_TEMPERATURE=0.0
ANTHROPIC_MAX_TOKENS=2048
ANTHROPIC_MAX_RETRIES=3
ANTHROPIC_TIMEOUT=30

# =============================================================================
# APPLICATION CONFIGURATION (App)
# =============================================================================
# 💡 Optional
APP_CONFIDENCE_THRESHOLD=0.7
APP_DEFAULT_CALENDAR_ID=primary

# =============================================================================
# LOGGING CONFIGURATION (App)
# =============================================================================
# 💡 Optional
LOG_LEVEL=DEBUG
LOG_CONSOLE_OUTPUT=true
LOG_FILE_OUTPUT=true

# =============================================================================
# 📝 CONFIGURATION APPROACH
# =============================================================================
# 🔧 MUST SET: You must customize these values for the system to function
# 📌 MUST EXIST: Required by system but have sensible defaults  
# 💡 OPTIONAL: Has reasonable defaults - customize if needed
#
# 🐳 DOCKER: Uses .env + .env.docker for container-specific overrides 